{
  "name": "express-extractor",
  "version": "1.0.0",
  "description": "Aplicación de escritorio para extracción de datos contables desde facturas mediante OCR",
  "type": "module",
  "main": "dist/server.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:server": "node --loader tsx server.ts",
    "dev:client": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node18 --outfile=dist/server.cjs --external:express --external:pdfjs-dist --external:tesseract.js --external:cors --external:dotenv --external:xlsx",
    "build:electron": "electron-builder",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "electron": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.3.3",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "xlsx": "^0.18.5",
    "lucide-react": "^0.408.0",
    "framer-motion": "^10.16.16",
    "pdfjs-dist": "^4.0.269",
    "tesseract.js": "^5.0.4",
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.7",
    "tailwindcss": "^3.3.6",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "esbuild": "^0.19.11",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.expressextractor.app",
    "productName": "Express Extractor",
    "files": [
      "dist/**/*",
      "electron.js",
      "public/**/*"
    ],
    "directories": {
      "buildResources": "public"
    }
  }
}
